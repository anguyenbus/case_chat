# Case Chat Environment Configuration
# Copy this file to .env and fill in your values
# WARNING: Never commit the actual .env file to version control

# ----------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------

# Deployment environment (development, staging, production)
CASE_CHAT_ENVIRONMENT=development

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
CASE_CHAT_LOG_LEVEL=INFO

# Default model ID for agents
# GLM-5 (Zhipu AI): glm-5, glm-4, etc.
CASE_CHAT_MODEL_ID=glm-5

# ----------------------------------------------------------------------
# API Keys
# ----------------------------------------------------------------------

# Zhipu AI API key (required for GLM models)
# Get your API key from: https://open.bigmodel.cn/usercenter/apikeys
z_api_key=your-zhipu-ai-api-key-here

# ----------------------------------------------------------------------
# MLflow Tracing Configuration
# ----------------------------------------------------------------------

# MLflow server tracking URI (required)
# Start MLflow server with: mlflow server --backend-store-uri sqlite:///mlflow.db --default-artifact-root ./mlflow-artifacts
MLFLOW_TRACKING_URI=http://localhost:5000

# MLflow experiment name (required)
# This groups all runs from this application together
MLFLOW_EXPERIMENT_NAME=case-chat-agent

# ----------------------------------------------------------------------
# Testing
# ----------------------------------------------------------------------

# Set to '1' to skip .env file loading (useful for testing)
# CASE_CHAT_SKIP_ENV_FILE=1
